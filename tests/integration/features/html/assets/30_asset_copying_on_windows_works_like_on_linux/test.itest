RUN: %strictdoc export %S --output-dir %T | filecheck %s --dump-input=fail
CHECK: Published: Hello world doc

RUN: %check_exists --dir %T/html/%THIS_TEST_FOLDER/prod_requirements/req/_assets
RUN: %check_exists --file %T/html/%THIS_TEST_FOLDER/prod_requirements/req/_assets/en62625-1_table2.png

RUN: %check_exists --file %T/html/%THIS_TEST_FOLDER/prod_requirements/req/input.html

RUN: %cat %T/html/%THIS_TEST_FOLDER/prod_requirements/req/input.html | filecheck %s --dump-input=fail --check-prefix CHECK-HTML
CHECK-HTML: <img{{.*}}src="_assets/en62625-1_table2.png"{{.*}}>
