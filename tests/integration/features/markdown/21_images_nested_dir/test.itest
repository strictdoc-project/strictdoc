RUN: %strictdoc export %S --formats=html --output-dir %T | filecheck %s --dump-input=fail
CHECK: Published: Images in nested Markdown document

RUN: %check_exists --dir %T/html/21_images_nested_dir/nested/_assets
RUN: %check_exists --file %T/html/21_images_nested_dir/nested/_assets/sandbox1.svg

RUN: %check_exists --file %T/html/21_images_nested_dir/nested/input.html

RUN: %cat %T/html/21_images_nested_dir/nested/input.html | filecheck %s --dump-input=fail --check-prefix CHECK-HTML
CHECK-HTML: <img src="_assets/sandbox1.svg" alt="Test image">
