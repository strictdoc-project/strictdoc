RUN: %strictdoc export %S --output-dir Output/ | filecheck %s --dump-input=fail --check-prefix CHECK-EXPORT
CHECK-EXPORT: Published: <b>"escaping" & 'title'</b>

RUN: %grep '.b[^\-].*escaping.*title.*b.' %S/Output/html/01_no_special_characters_passed_to_output/input.html | filecheck %s --dump-input=fail
RUN: %grep '.b[^\-].*escaping.*section.*b.' %S/Output/html/01_no_special_characters_passed_to_output/input.html | filecheck %s --dump-input=fail
RUN: %grep '.b[^\-].*escaping.*statement.*b.' %S/Output/html/01_no_special_characters_passed_to_output/input.html | filecheck %s --dump-input=fail
RUN: %grep '.b[^\-].*escaping.*title.*b.' %S/Output/html/01_no_special_characters_passed_to_output/input.html | filecheck %s --dump-input=fail
CHECK-NOT: {{["<>]}}
CHECK-NOT: {{& }}
