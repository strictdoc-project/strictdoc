{#
  Field with optional copy button — handled by the delegated document-level listener
  in copy_to_clipboard.js.

  To enable the copy button, declare before including this template:
    {% set copy_to_clipboard = True %}

  When enabled, the delegated copy_to_clipboard.js script reads the text content of
  sdoc-field-content at click time.

  Expected structure (used by copy_to_clipboard.js):
    sdoc-field                           — boundary for closest() lookup
    sdoc-field-content                   — source of the text to copy
    sdoc-field-service                   — feedback root for icons and cover animation
    data-copy-clipboard-target="button"  — marks the copy button
    data-copy-clipboard-target="cover"   — orange fade animation
    data-copy-clipboard-target="copyIcon"
    data-copy-clipboard-target="doneIcon"

  ! Enabling this option for PDF is highly not recommended.

  Requires: field_content
#}

{%- if copy_to_clipboard is defined -%}
<sdoc-field>
  <sdoc-field-content>
    <sdoc-autogen>{{ field_content }}</sdoc-autogen>
  </sdoc-field-content>
  <sdoc-field-service>

    <div class="copy_to_clipboard">
      <div class="copy_to_clipboard-cover" data-copy-clipboard-target="cover">
        <div title="Click to copy" class="copy_to_clipboard-button action_button" data-copy-clipboard-target="button">
          <span style="display: contents;" data-copy-clipboard-target="copyIcon">
            {% include "icons/ico16_copy.svg" %}
          </span>
          <span style="display: none;" data-copy-clipboard-target="doneIcon">
            {% include "icons/ico16_done.svg" %}
          </span>
        </div>
      </div>
    </div>

  </sdoc-field-service>
</sdoc-field>
{%- else -%}
<sdoc-autogen>{{ field_content }}</sdoc-autogen>
{%- endif -%}
