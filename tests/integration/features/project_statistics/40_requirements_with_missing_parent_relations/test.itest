#
# This test verifies the following functionality:
# Project statistics include a metric that counts requirements
# with missing relations when this behavior is enabled.
#

RUN: %strictdoc export %S --output-dir %T | filecheck %s --dump-input=fail
CHECK: Published: Hello world doc
CHECK: warning: unresolved parent requirement relations were detected and allowed by configuration.

RUN: %check_exists --file "%T/html/project_statistics.html"

RUN: %cat "%T/html/project_statistics.html" | filecheck %s --dump-input=fail --check-prefix CHECK-HTML
CHECK-HTML: Requirements with missing relations
CHECK-HTML: 1
