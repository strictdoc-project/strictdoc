<a
  class="dropdown_menu_item"
  href="/actions/project_index/new_document"
  data-turbo="true"
  title="Add new document"
  data-testid="tree-add-document-action"
  role="menuitem"
>{% include "icons/ico16_add.svg" %} Add document</a>

{%- if view_object.project_config.is_activated_reqif() -%}
<a
  class="dropdown_menu_item"
  href="/actions/project_index/import_reqif_document_form"
  data-turbo="true"
  title="Import document tree from ReqIF"
  data-testid="tree-import-reqif-action"
  role="menuitem"
>{% include "icons/ico16_import.svg" %} Import from ReqIF</a>

{%- if not view_object.is_empty_tree() -%}
<a
  class="dropdown_menu_item"
  href="/reqif/export_tree"
  title="Export document tree to ReqIF"
  data-testid="tree-export-reqif-action"
  role="menuitem"
>{% include "icons/ico16_export.svg" %} Export to ReqIF</a>
{%- endif -%}
{%- endif -%}
