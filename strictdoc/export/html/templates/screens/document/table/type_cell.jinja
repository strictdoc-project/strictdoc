<td class="content-view-td content-view-td-type">
  <div class="content-view-td-type__content">
    <span>{{ node.node_type }}</span>
    <div class="content-view-td-type__actions">
      {%- if view_object.is_running_on_server -%}
      <span class="table-node-delete-action">
        {%- set delete_name -%}
          {%- include "icons/ico16_delete.svg" -%}
        {%- endset -%}
        {%- if view_object.can_delete_node(node) -%}
          {%- with
            delete_href="/actions/table/delete_node?node_id="~node.reserved_mid~
              "&context_document_mid="~view_object.document.reserved_mid
          -%}
            {%- include "components/button_inline/delete.jinja" -%}
          {%- endwith -%}
        {%- else -%}
          <a
            class="action_icon action_button--disabled"
            title="Deleting is disabled for autogenerated content"
            data-action-type="delete"
            data-testid="form-delete-action-disabled"
          >{{ delete_name }}</a>
        {%- endif -%}
      </span>
      {%- endif -%}
      {# FIXME: rough draft for the Row highlighting function #}
      {# <span class="table-node-highlight-action">
        <span class="action_icon">
          {%- include "icons/ico16_star.svg" -%}
        </span>
      </span> #}
    </div>
  </div>
</td>
