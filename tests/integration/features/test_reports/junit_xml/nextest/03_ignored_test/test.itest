# cargo-nextest filters out #[ignore]-annotated tests before the test binary
# runs, so they do not appear in the JUnit XML at all (neither as <skipped>
# nor in tests="N"). This fixture checks that StrictDoc reports the one test
# that ran and does not invent a result for the ignored test.

RUN: %strictdoc export %S --output-dir %T | filecheck %s --dump-input=fail

# Ensure that the test report document is generated.
CHECK: Published: Test report: hello_world_crate
RUN: %check_exists --file "%T/html/%THIS_TEST_FOLDER/reports/tests_unit.nextest.junit.html"

# Ensure that the source file is generated.
RUN: %check_exists --file "%T/html/_source_files/src/lib.rs.html"

# The test that ran is reported as PASSED and linked to its source; the
# #[ignore]-annotated test is absent from the report.
RUN: %cat "%T/html/%THIS_TEST_FOLDER/reports/tests_unit.nextest.junit.html" | filecheck %s --check-prefix CHECK-TEST-REPORT
CHECK-TEST-REPORT: hello_world_crate::tests::add_works
CHECK-TEST-REPORT: PASSED
CHECK-TEST-REPORT: src/lib.rs, <i>lines: 11-13</i>, function lib::tests::add_works()
CHECK-TEST-REPORT-NOT: always_ignored
