{%- assert field_title is defined, "field_title is defined" -%}
{%- assert field_value is defined, "field_value is defined" -%}
{%- assert td_class is defined, "td_class is defined" -%}
{#
  Renders a SingleChoice / MultipleChoice / Tag field cell — display only.
  On click in edit mode JS fetches the inline form from data-url (turbo-stream),
  which injects the autocompletable component into the cell div.
  On blur JS saves via /actions/table/update_node_field and the turbo-stream
  response restores the display content.
#}
<td class="{{ td_class }}"
    data-node-mid="{{ requirement.reserved_mid }}"
    data-field-name="{{ field_title }}"
    data-field-type="autocomplete"
    data-current-value="{{ field_value if field_value else '' }}"
    data-url="/actions/table/get_node_autocomplete_inline?node_mid={{ requirement.reserved_mid }}&field_name={{ field_title }}">
  <div id="cell-{{ requirement.reserved_mid }}-{{ field_title }}">
    {%- if field_value %}
      {%- with field_content = field_value %}
        {%- include "screens/document/table/field_display_mode/_field.jinja" -%}
      {%- endwith -%}
    {%- endif %}
  </div>
</td>
