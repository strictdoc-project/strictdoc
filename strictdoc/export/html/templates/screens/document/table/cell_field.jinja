{#
  Dispatcher for grammar-defined field cells in the loop columns.
  Called from main.jinja for: meta field loops and non-reserved content field loops.
  NOT used for STATEMENT / RATIONALE / COMMENT / RELATIONS — those are hardcoded
  individually in main.jinja because they occupy fixed columns at specific positions
  in the table header (between TITLE and the dynamic content fields). Putting them
  in a loop would break the column order.
  Additional differences that keep STATEMENT / RATIONALE separate:
  - Python accessors differ: requirement.reserved_statement / requirement.rationale
    vs requirement.get_meta_field_value_by_title(field_title) used here.
  - Renderers differ: view_object.render_node_statement() / render_node_rationale()
    vs view_object.render_node_field() used here for generic multiline fields.

  Expects: field_title, field_value, cell_edit_mode, td_class, requirement, node

  cell_edit_mode comes from view_object.get_table_cell_edit_mode() and
  reflects the grammar field type. It maps directly to data-field-type:
    "autocomplete" — SingleChoice / MultipleChoice / Tag  → data-field-type="autocomplete"
    "singleline"   — single-line STRING (UID, VERSION, …) → data-field-type="singleline"
    "multiline"    — multi-line STRING (content fields)   → data-field-type="multiline"
    "readonly"     — field not in grammar for this type   → plain <td>, no data-field-type
#}

{%- if cell_edit_mode == "autocomplete" %}
{#
  Delegates entirely to cell_autocompletable.jinja.
  That file renders the full <td> with both display and edit elements in the DOM.
#}
{%- include "screens/document/table/cell_autocompletable.jinja" %}

{%- elif cell_edit_mode == "singleline" %}
{#
  Plain text value — no markup rendering.
  JS fetches the inline form from data-url on click (GET get_node_singleline_inline).
  Server returns a turbo-stream with a single-line contenteditable form.
  On blur / outside click JS POSTs the form to /actions/table/update_node_field.
#}
<td class="{{ td_class }}"
    data-node-mid="{{ requirement.reserved_mid }}"
    data-field-name="{{ field_title }}"
    data-field-type="singleline"
    data-url="/actions/table/get_node_singleline_inline?node_mid={{ requirement.reserved_mid }}&field_name={{ field_title }}">
  <div id="cell-{{ requirement.reserved_mid }}-{{ field_title }}">
    {%- if field_value %}
      {%- with field_content = field_value %}
        {%- include "screens/document/table/field_display_mode/_field.jinja" -%}
      {%- endwith -%}
    {%- endif %}
  </div>
</td>

{%- elif cell_edit_mode == "multiline" %}
{#
  Rendered through the markup renderer (RST/Markdown → HTML) via
  view_object.render_node_field(), same as STATEMENT and RATIONALE.
  JS fetches an inline contenteditable form from data-url on click
  (GET get_node_multiline_inline), injects it into the cell via turbo-stream.
  On blur / outside click JS POSTs the form to
  /actions/table/update_node_field_multiline.
#}
<td class="{{ td_class }}"
    data-node-mid="{{ requirement.reserved_mid }}"
    data-field-name="{{ field_title }}"
    data-field-type="multiline"
    data-url="/actions/table/get_node_multiline_inline?node_mid={{ requirement.reserved_mid }}&field_name={{ field_title }}">
  <div id="cell-{{ requirement.reserved_mid }}-{{ field_title }}">
    {%- if field_value %}
      {%- with field_content = view_object.render_node_field(requirement.ordered_fields_lookup[field_title][0]) %}
        {%- include "screens/document/table/field_display_mode/_field.jinja" -%}
      {%- endwith -%}
    {%- endif %}
  </div>
</td>

{%- else %}
{#
  "readonly": field not declared in grammar for this element type.
  Static cell, no edit affordances.
#}
<td class="{{ td_class }}">
  {%- if field_value %}
    {%- with field_content = field_value %}
      {%- include "screens/document/table/field_display_mode/_field.jinja" -%}
    {%- endwith -%}
  {%- endif %}
</td>
{%- endif %}
