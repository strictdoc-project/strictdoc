{#
  js-table_view_edit-form identifies the form submitted by table_view_edit.js.
  The hook keeps the script independent from the form's position in the field DOM.
#}
<form
  action="/actions/table/update_document_config_field"
  method="POST"
  data-turbo="false"
  js-table_view_edit-form
>
  <input type="hidden" name="document_mid" value="{{ document_mid }}"/>
  <input type="hidden" name="field_name" value="{{ field_name }}"/>

  {%- with
    field_class_name=none,
    field_editable=true,
    field_input_name="field_value",
    field_label=field_name,
    field_placeholder="Enter " ~ field_name ~ " here...",
    field_type="singleline",
    field_value=current_value,
    testid_postfix=field_name,
    errors=[]
  -%}
    {%- include "components/form/field/contenteditable/index.jinja" %}
  {%- endwith -%}
</form>
