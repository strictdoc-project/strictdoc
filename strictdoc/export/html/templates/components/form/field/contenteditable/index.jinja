{%- assert field_class_name is defined, "field_class_name is defined" -%}
{%- assert field_editable is defined, "field_editable is defined" -%}
{%- assert field_input_name is defined, "field_input_name is defined" -%}
{%- assert field_label is defined, "field_label is defined" -%}
{%- assert field_label is not none, "field_label is not none" -%}
{%- assert field_placeholder is defined, "field_placeholder is defined" -%}
{%- assert field_placeholder is not none, "field_placeholder is not none" -%}
{%- assert field_value is defined, "field_value is defined" -%}
{%- assert testid_postfix is defined, "testid_postfix is defined" -%}
{#
  mid is optional:
  - Pass mid when the field belongs to a dynamic row with its own identity
    (grammar elements, grammar relations, custom fields, metadata rows).
    In those cases mid is used as a DOM selector in e2e tests to
    identify a specific row among several similar ones.
  - Omit mid for static single-instance fields (document TITLE, UID,
    VERSION, project title, etc.) where data-testid alone is sufficient.
#}

{% if field_required is not defined -%}
{% set field_required=false -%}
{%- endif -%}

{#
  By default, field errors are rendered inside <sdoc-form-field>, immediately
  after the input control. Set field_render_errors=false when a parent row
  renders the same error list in a shared location. The errors collection is
  still used above to mark the affected <sdoc-contenteditable> with
  errors="true".
#}
{% if field_render_errors is not defined -%}
{% set field_render_errors=true -%}
{%- endif -%}

{#
  CSS note:
  Flex order in <sdoc-form-field> should not be used to ensure that the output
  of an error block affects the contenteditable physically following it.
  So the <sdoc-form-error> block should be inside the <sdoc-form-field>,
  which must necessarily have "display:block", but after the contenteditable.
  Otherwise, unnecessary spaces are produced in the content,
  and it breaks Selenium's end2end tests.
#}

<sdoc-form-field>
  <sdoc-contenteditable
    {% if errors is defined and errors|length -%}
      errors="true"
    {%- endif %}
    {% if field_required -%}
      required="true"
    {%- endif %}
    data-controller="editablefield"
    role="textbox"
    data-field-type="{{ field_type }}"
    {%- if field_editable is defined and not field_editable -%}
      contenteditable="false"
    {%- else -%}
      contenteditable="true"
    {%- endif -%}
    id="{{ field_input_name }}"
    {%- if mid is defined -%}
      mid="{{ mid }}"
    {% endif %}
    placeholder="{{ field_placeholder }}"
    {%- if field_type == "singleline" and singleline_suffix is defined -%}
      data-field-suffix="{{ singleline_suffix }}"
    {%- endif -%}
    data-field-label="{{ field_label }}{%- if field_required -%}&nbsp;*{%- endif -%}"
    {%- if field_class_name is not none -%}
      class="{{ field_class_name }}"
    {%- endif -%}
    data-testid="form-field-{{ testid_postfix }}"
  >
    {{- field_value -}}
  </sdoc-contenteditable>

  {%- if field_type == "singleline" -%}
    <input type="hidden" name="{{ field_input_name }}" value="{{ field_value }}" {% if field_required %}required{% endif %}/>
  {%- endif -%}

  {%- if field_type == "multiline" -%}
    <textarea hidden name="{{ field_input_name }}" {% if field_required %}required{% endif %}>
      {{- field_value -}}
    </textarea>
  {%- endif -%}

  {%- if
    field_render_errors
    and errors is defined
    and errors|length > 0
  -%}
    {%- for error_ in errors -%}
    <sdoc-form-error>
      {{ error_ }}
    </sdoc-form-error>
    {%- endfor -%}
  {%- endif -%}

</sdoc-form-field>
