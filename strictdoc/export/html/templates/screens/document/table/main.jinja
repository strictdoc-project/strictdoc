{#
  TABLE VIEW — INLINE EDITING OVERVIEW
  =====================================

  This template renders all nodes as a flat table (requirements and sections).
  By default the table is in display (read-only) mode.

  ACTIVATING EDIT MODE
  ---------------------
  The toolbar button [data-testid="table-toolbar-edit-btn"] toggles edit mode.
  Clicking it adds the CSS class "table--is-editable" to <table> (not in use),
  and [data-mode="edit"] to .main container.
  CSS rules in table_view.css make editable cells show cursor:pointer and a
  hover outline — only when that class is present.

  CELL EDITING MODES  (data-field-type attribute on <td>)
  --------------------------------------------------------
  "singleline"
      JS fetches the inline form from the URL stored in data-url attribute
      (GET /actions/table/get_node_singleline_inline).
      Server returns a turbo-stream that replaces the cell content with a
      single-line contenteditable form. On blur / outside click: JS POSTs the
      form to /actions/table/update_node_field, server updates
      <div id="cell-{mid}-{field}"> via turbo-stream.

  "multiline"
      JS fetches the inline form from the URL stored in data-url attribute
      (GET /actions/table/get_node_contenteditable_inline).
      Server returns a turbo-stream that replaces the cell content with a
      multi-line contenteditable form. On blur / outside click: JS POSTs the
      form to /actions/table/update_node_field_multiline, server updates
      <div id="cell-{mid}-{field}"> via turbo-stream.

  "comments"
      JS fetches /actions/table/get_node_comments_inline?node_mid=...
      Server returns an inline form with multiple comment fields.
      On blur / outside click: JS POSTs the form, server updates
      <div id="cell-{mid}-COMMENT"> via turbo-stream.

  "relations"
      JS fetches /actions/table/get_node_relations_inline?node_mid=...
      Server returns an inline form with relation rows (editable) and
      computed/derived relations (read-only).
      On blur / outside click: JS POSTs the form, server updates
      <div id="cell-{mid}-RELATIONS"> via turbo-stream.

  "autocomplete"
      A Stimulus controller (autocompletable) is already present in the DOM.
      Edit mode CSS hides .cell-display and shows .cell-edit-ac (contenteditable).
      On blur: JS POSTs to /actions/table/update_node_field via fetch.

  JS handles "singleline", "multiline", "comments", "relations" identically
  (openInlineCell / saveInlineCell). The distinction is purely server-side:
  different GET endpoints inject different form shapes; different POST endpoints
  process them.

  CELL EDITABILITY (is_table_cell_editable / get_table_cell_edit_mode)
  ----------------------------------------------------------------------
  Whether a field is editable depends on the document grammar for that node
  type. view_object.is_table_cell_editable() returns True if the field is
  declared in the grammar. get_table_cell_edit_mode() returns the Python grammar
  value: "autocomplete" | "singleline" | "multiline" | "readonly".
  td_by_edit_mode.jinja maps grammar values to data-field-type DOM attributes:
  "singleline" and "multiline" → data-field-type="contenteditable" (same component, server decides form shape).

  COLUMN VISIBILITY
  -----------------
  Columns are driven by view_object.document.enumerate_table_columns(),
  which yields only columns present in at least one grammar element.
  TYPE and LEVEL are always rendered as the two fixed first columns.
  When a column exists in the document grammar but a specific node's grammar
  does not declare that field, the cell gets the "content-view-td--dimmed" modifier.
#}
{%- if view_object.has_any_nodes() -%}
  <div class="main"
       js-pan_with_space="true"
       js-table_view_edit
  >
    {% include "_shared/tags.jinja.html" %}
      <div class="content">

        {# ================================================================ #}
        {# ROOT NODE / TITLE + META                                         #}
        {# similar: components/node_field/document_meta/index.jinja         #}
        {# ================================================================ #}
        {%- set doc_mid = view_object.document.reserved_mid -%}
        {%- set document_config = view_object.document.config -%}
        <sdoc-node>
          <h1 data-testid="document-title">
            {%- with
              field_content=view_object.document.title,
              document_title_wrap=true
            -%}
              {%- include "screens/document/table/field_display_mode/document_title.jinja" -%}
            {%- endwith %}
            {%- with local_anchor = view_object.render_local_anchor(view_object.document) -%}
              {% include "components/anchor_document/index.jinja" %}
            {%- endwith %}
          </h1>

          {{ view_object.render_issues(view_object.document) }}

          <sdoc-meta>
            {# -- UID ---------------------------------------------------- #}
            {%- with
              field_content=document_config.uid,
              field_label="UID",
              field_name="UID",
              field_testid="uid"
            -%}
              {%- include "screens/document/table/field_display_mode/document_config_field.jinja" -%}
            {%- endwith -%}

            {# -- VERSION ------------------------------------------------ #}
            {%- set document_version_ = view_object.render_document_version() -%}
            {%- with
              field_content=document_version_,
              field_label="VERSION",
              field_name="VERSION",
              field_testid="version"
            -%}
              {%- include "screens/document/table/field_display_mode/document_config_field.jinja" -%}
            {%- endwith -%}

            {# -- DATE (read-only) --------------------------------------- #}
            {%- set document_date_ = view_object.render_document_date() -%}
            {%- if document_date_ is not none -%}
              {%- with
                field_content=document_date_,
                field_label="DATE",
                field_testid="date"
              -%}
                {%- include "screens/document/table/field_display_mode/document_meta_readonly_field.jinja" -%}
              {%- endwith -%}
            {%- endif -%}

            {# -- CLASSIFICATION ----------------------------------------- #}
            {%- with
              field_content=document_config.classification,
              field_label="CLASSIFICATION",
              field_name="CLASSIFICATION",
              field_testid="classification"
            -%}
              {%- include "screens/document/table/field_display_mode/document_config_field.jinja" -%}
            {%- endwith -%}

            {# -- PREFIX ------------------------------------------------- #}
            {%- with
              field_content=document_config.requirement_prefix,
              field_label="PREFIX",
              field_name="PREFIX",
              field_testid="prefix"
            -%}
              {%- include "screens/document/table/field_display_mode/document_config_field.jinja" -%}
            {%- endwith -%}

            {# -- CUSTOM METADATA ---------------------------------------- #}
            {%- include "screens/document/table/field_display_mode/document_custom_meta.jinja" -%}

          </sdoc-meta>

        </sdoc-node>

        {# ================================================================ #}
        {# TABLE                                                            #}
        {# ================================================================ #}
        {#
          column_labels maps internal column IDs to display names.
          Dynamic fields (meta / non-reserved content) use their title as-is.
        #}
        {%- set column_labels = {
          "RELATIONS": "REFS",
          "TITLE":     "Title",
          "STATEMENT": "Statement",
          "RATIONALE": "Rationale",
          "COMMENT":   "Comment"
        } -%}
        <table class="content-view-table" js-table_view_edit-table>

          {# -- Header row ------------------------------------------------ #}
          <thead class="content-view-table_sticky-header">
            <tr>
              <th class="content-view-th" data-testid="col-header-Type">
                <div class="content-view-th__content">
                  <span class="content-view-th__label">Type</span>
                  <button class="content-view-th__sort-btn" aria-label="Sort by Type">{%- include "icons/ico16_sort.svg" -%}</button>
                </div>
              </th>
              <th class="content-view-th" data-testid="col-header-Level">
                <div class="content-view-th__content">
                  <span class="content-view-th__label">Level</span>
                  <button class="content-view-th__sort-btn" aria-label="Sort by Level">{%- include "icons/ico16_sort.svg" -%}</button>
                </div>
              </th>
              {%- for column in view_object.document.enumerate_table_columns() -%}
                {%- set col_label = column_labels.get(column, column) -%}
                <th class="content-view-th" data-testid="col-header-{{ col_label }}">
                  <div class="content-view-th__content">
                    <span class="content-view-th__label">{{ col_label }}</span>
                    <button class="content-view-th__sort-btn" aria-label="Sort by {{ col_label }}">{%- include "icons/ico16_sort.svg" -%}</button>
                  </div>
                </th>
              {%- endfor -%}
            </tr>
          </thead>

          {# -- Body rows ------------------------------------------------- #}
          <tbody>
          {%- for node, _ in view_object.document_content_iterator() %}

            {# ============================================================ #}
            {# REQUIREMENT ROW                                              #}
            {# ============================================================ #}
            {%- if node.is_requirement() %}
              {%- set requirement = node %}
              <tr data-row-type="{{ node.node_type }}" data-node-mid="{{ requirement.reserved_mid }}">

                {# -- Type & Level ---------------------------------------- #}
                <td class="content-view-td content-view-td-type">
                  {{ node.node_type }}
                </td>
                <td class="content-view-td content-view-td-level">
                  {{ requirement.context.title_number_string }}
                </td>

                {#
                  Loop over all document columns.
                  ns.past_reserved becomes true when we enter the reserved-column
                  region (RELATIONS / TITLE / STATEMENT / RATIONALE / COMMENT), so
                  that dynamic fields before that region get the "meta" cell class
                  and dynamic fields after it get the plain content cell class.
                #}
                {%- set ns = namespace(past_reserved=false) %}
                {%- for column in view_object.document.enumerate_table_columns() %}

                  {%- if column == "RELATIONS" %}
                    {%- set ns.past_reserved = true %}
                    {# -- RELATIONS --------------------------------------- #}
                    <td class="editable-cell content-view-td content-view-td-meta content-view-td-related"
                        data-node-mid="{{ requirement.reserved_mid }}"
                        data-field-name="RELATIONS"
                        data-field-type="relations"
                        js-table_view_edit-field="relations"
                        data-url="/actions/table/get_node_relations_inline?node_mid={{ requirement.reserved_mid }}">
                      <div class="editable-cell-indicator"></div>
                      <div id="cell-{{ requirement.reserved_mid }}-RELATIONS" wrapper-field-type="contenteditable">
                        {%- include "screens/document/table/field_display_mode/relations.jinja" %}
                      </div>
                    </td>

                  {%- elif column == "TITLE" %}
                    {%- set ns.past_reserved = true %}
                    {# -- TITLE ------------------------------------------- #}
                    {%- if view_object.is_table_cell_editable(node.node_type, "TITLE") %}
                    <td class="editable-cell content-view-td content-view-td-title"
                        data-node-mid="{{ requirement.reserved_mid }}"
                        data-field-name="TITLE"
                        data-field-type="contenteditable"
                        js-table_view_edit-field="contenteditable"
                        data-url="/actions/table/get_node_contenteditable_inline?node_mid={{ requirement.reserved_mid }}&field_name=TITLE">
                      <div class="editable-cell-indicator"></div>
                      <div id="cell-{{ requirement.reserved_mid }}-TITLE" wrapper-field-type="contenteditable">
                        {%- if requirement.reserved_title %}
                          {%- with sdoc_entity=requirement -%}
                            {% include "components/anchor/index.jinja" %}
                          {%- endwith %}
                          {%- with field_content = requirement.reserved_title %}
                            {%- include "screens/document/table/field_display_mode/title.jinja" -%}
                          {%- endwith -%}
                        {%- endif -%}
                      </div>
                    </td>
                    {%- else %}
                    <td class="content-view-td content-view-td-title content-view-td--dimmed"
                        data-field-name="TITLE">
                      {%- if requirement.reserved_title %}
                        {%- with sdoc_entity=requirement -%}
                          {% include "components/anchor/index.jinja" %}
                        {%- endwith %}
                        {%- with field_content = requirement.reserved_title %}
                          {%- include "screens/document/table/field_display_mode/title.jinja" -%}
                        {%- endwith -%}
                      {%- endif -%}
                    </td>
                    {%- endif %}

                  {%- elif column == "STATEMENT" %}
                    {%- set ns.past_reserved = true %}
                    {# -- STATEMENT --------------------------------------- #}
                    {%- if view_object.is_table_cell_editable(node.node_type, "STATEMENT") %}
                    <td class="editable-cell content-view-td content-view-td-content"
                        data-node-mid="{{ requirement.reserved_mid }}"
                        data-field-name="STATEMENT"
                        data-field-type="contenteditable"
                        js-table_view_edit-field="contenteditable"
                        data-url="/actions/table/get_node_contenteditable_inline?node_mid={{ requirement.reserved_mid }}&field_name=STATEMENT">
                      <div class="editable-cell-indicator"></div>
                      <div id="cell-{{ requirement.reserved_mid }}-STATEMENT" wrapper-field-type="contenteditable">
                        {%- if requirement.has_reserved_statement() -%}
                          {%- with field_content = view_object.render_node_statement(requirement) %}
                            {%- include "screens/document/table/field_display_mode/statement.jinja" -%}
                          {%- endwith -%}
                        {%- endif -%}
                      </div>
                    </td>
                    {%- else %}
                    <td class="content-view-td content-view-td-content content-view-td--dimmed"
                        data-field-name="STATEMENT">
                      {%- if requirement.has_reserved_statement() -%}
                        {%- with field_content = view_object.render_node_statement(requirement) %}
                          {%- include "screens/document/table/field_display_mode/statement.jinja" -%}
                        {%- endwith -%}
                      {%- endif -%}
                    </td>
                    {%- endif %}

                  {%- elif column == "RATIONALE" %}
                    {%- set ns.past_reserved = true %}
                    {# -- RATIONALE --------------------------------------- #}
                    {%- if view_object.is_table_cell_editable(node.node_type, "RATIONALE") %}
                    <td class="editable-cell content-view-td content-view-td-content"
                        data-node-mid="{{ requirement.reserved_mid }}"
                        data-field-name="RATIONALE"
                        data-field-type="contenteditable"
                        js-table_view_edit-field="contenteditable"
                        data-url="/actions/table/get_node_contenteditable_inline?node_mid={{ requirement.reserved_mid }}&field_name=RATIONALE">
                      <div class="editable-cell-indicator"></div>
                      <div id="cell-{{ requirement.reserved_mid }}-RATIONALE" wrapper-field-type="contenteditable">
                        {%- if requirement.rationale -%}
                          {%- with field_content = view_object.render_node_rationale(requirement) %}
                            {%- include "screens/document/table/field_display_mode/rationale.jinja" -%}
                          {%- endwith -%}
                        {%- endif -%}
                      </div>
                    </td>
                    {%- else %}
                    <td class="content-view-td content-view-td-content content-view-td--dimmed"
                        data-field-name="RATIONALE">
                      {%- if requirement.rationale -%}
                        {%- with field_content = view_object.render_node_rationale(requirement) %}
                          {%- include "screens/document/table/field_display_mode/rationale.jinja" -%}
                        {%- endwith -%}
                      {%- endif -%}
                    </td>
                    {%- endif %}

                  {%- elif column == "COMMENT" %}
                    {%- set ns.past_reserved = true %}
                    {# -- COMMENT ----------------------------------------- #}
                    {%- if view_object.is_table_cell_editable(node.node_type, "COMMENT") %}
                    <td class="editable-cell content-view-td content-view-td-content"
                        data-node-mid="{{ requirement.reserved_mid }}"
                        data-field-name="COMMENT"
                        data-field-type="comments"
                        js-table_view_edit-field="comments"
                        data-url="/actions/table/get_node_comments_inline?node_mid={{ requirement.reserved_mid }}">
                      <div class="editable-cell-indicator"></div>
                      <div id="cell-{{ requirement.reserved_mid }}-COMMENT" wrapper-field-type="comments">
                        {%- for comment_field_ in requirement.get_comment_fields() -%}
                        {%- with field_content = view_object.render_node_field(comment_field_) %}
                          {%- include "screens/document/table/field_display_mode/comment.jinja" -%}
                        {%- endwith -%}
                        {%- endfor -%}
                      </div>
                    </td>
                    {%- else %}
                    <td class="content-view-td content-view-td-content content-view-td--dimmed"
                        data-field-name="COMMENT">
                      {%- for comment_field_ in requirement.get_comment_fields() -%}
                      {%- with field_content = view_object.render_node_field(comment_field_) %}
                        {%- include "screens/document/table/field_display_mode/comment.jinja" -%}
                      {%- endwith -%}
                      {%- endfor -%}
                    </td>
                    {%- endif %}

                  {%- else %}
                    {# -- Dynamic field (meta or non-reserved content) ----- #}
                    {%- set field_title = column %}
                    {%- set field_value = requirement.get_meta_field_value_by_title(field_title) %}
                    {%- set cell_edit_mode = view_object.get_table_cell_edit_mode(node.node_type, field_title) %}
                    {%- if ns.past_reserved %}
                      {%- set td_class = "content-view-td" %}
                    {%- else %}
                      {%- set td_class = "content-view-td content-view-td-meta" %}
                    {%- endif %}
                    {%- include "screens/document/table/td_by_edit_mode.jinja" %}
                  {%- endif %}

                {%- endfor %}

              </tr>

            {# ============================================================ #}
            {# SECTION ROW (document node = section heading)                #}
            {# ============================================================ #}
            {%- elif node.is_document() %}
              {%- set section = node %}

              {#
                Compute colspan for the section title cell.
                The title cell spans all columns from TITLE to the end of the row.
              #}
              {%- set ns_span = namespace(count=0, counting=false) %}
              {%- for column in view_object.document.enumerate_table_columns() %}
                {%- if column == "TITLE" %}
                  {%- set ns_span.counting = true %}
                {%- endif %}
                {%- if ns_span.counting %}
                  {%- set ns_span.count = ns_span.count + 1 %}
                {%- endif %}
              {%- endfor %}

              <tr data-row-type="SECTION">
                <td class="content-view-td content-view-td-type">Section</td>
                <td class="content-view-td content-view-td-meta">{{ section.context.title_number_string }}</td>

                {%- set ns_sec = namespace(past_title=false) %}
                {%- for column in view_object.document.enumerate_table_columns() %}
                  {%- if ns_sec.past_title %}
                    {# skip — covered by the TITLE colspan cell #}
                  {%- elif column == "TITLE" %}
                    {%- set ns_sec.past_title = true %}
                    <td class="content-view-td content-view-td-title" colspan="{{ ns_span.count if ns_span.count > 0 else 1 }}">
                      {%- if section.title %}
                        {%- with sdoc_entity=section -%}
                          {% include "components/anchor/index.jinja" %}
                        {%- endwith %}
                        <sdoc-node-title>
                          {%- with field_content = section.title %}
                            {%- include "screens/document/table/field_display_mode/_base_field_component.jinja" -%}
                          {%- endwith -%}
                        </sdoc-node-title>
                      {%- endif -%}
                    </td>
                  {%- else %}
                    {# RELATIONS or meta field — empty cell #}
                    <td class="content-view-td content-view-td-meta"></td>
                  {%- endif %}
                {%- endfor %}

              </tr>
            {%- endif %}

          {%- endfor %}
          </tbody>
        </table>
      </div>
      {# /.content #}
  </div>
  {# /.main #}
{%- else -%}
  <sdoc-main-placeholder data-testid="document-main-placeholder">
  This view is empty because
  <br />
  the document has no content.
  </sdoc-main-placeholder>
{%- endif -%}
