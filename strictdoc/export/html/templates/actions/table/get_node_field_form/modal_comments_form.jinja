{% extends "components/modal/form.jinja" %}
{% set form = "sdoc_modal_form" %}
{% block modal__context %}{% endblock modal__context %}
{% block modal_form__header %}
Edit Comments
{% endblock modal_form__header %}
{% block modal_form__content %}
  <form
    id="{{ form }}"
    action="/actions/table/update_node_comments"
    method="POST"
    data-turbo="true"
  >
    <input type="hidden" name="requirement_mid" value="{{ form_object.requirement_mid }}"/>
    <input type="hidden" name="document_mid" value="{{ form_object.document_mid }}"/>
    <input type="hidden" name="context_document_mid" value="{{ form_object.context_document_mid }}"/>
    <input type="hidden" name="element_type" value="{{ form_object.element_type }}"/>
    <input type="hidden" name="revision" value="{{ form_object.revision }}"/>

    {#-
      WHY ALL NON-COMMENT FIELDS ARE SENT AS HIDDEN INPUTS:

      The save endpoint uses RequirementFormObject.create_from_request(), which
      reconstructs the full node object from the submitted form data only.
      Any field absent from the form is treated as deleted and not written to the file.

      Other table fields (TITLE, STATEMENT, etc.) avoid this by using a different
      approach: the server loads the existing node via create_from_requirement() and
      patches just the one changed field — so only the new value needs to be sent.

      For comments, that patch approach would require a custom parser for the nested
      multi-value comment structure (each comment has its own mid and can be
      added/removed). Instead, we reuse the existing create_from_request() logic,
      which already handles that structure correctly — at the cost of passing all
      other fields as hidden inputs here so they are not lost on save.

      This is a deliberate compromise, localized entirely to this file.
      It can be replaced later with a targeted patch approach if needed.
    -#}
    {%- set form_data_turbo = "true" %}
    {%- include "screens/document/table/field_edit_mode/comments_body.jinja" %}
  </form>
{% endblock modal_form__content %}
{% block modal_form__footer_submit %}
  {%- with name="Save" -%}
    {% include "components/button/submit.jinja" %}
  {%- endwith -%}
{% endblock modal_form__footer_submit %}
