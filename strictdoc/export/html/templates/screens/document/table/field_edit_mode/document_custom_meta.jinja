{#
  Inline editor for one existing custom metadata value.

  The editor is rendered inside the persistent shared metadata form. form_key is
  a local form/DOM transport key, not a StrictDoc MID or persistent identifier.
  active_form_key tells the block-save endpoint which value target to update.
  Validation errors belong to the complete metadata row and are inserted after
  its field by the surrounding Turbo Stream template.
#}
<input type="hidden" name="active_form_key" value="{{ form_key }}"/>

{%- with
  field_class_name=none,
  field_editable=true,
  field_input_name="metadata[" ~ form_key ~ "][value]",
  field_label=field_label,
  field_placeholder="Enter " ~ field_label ~ " value here...",
  field_type="singleline",
  field_value=field_value,
  testid_postfix="metadata-" ~ form_key,
  errors=errors,
  field_render_errors=false
-%}
  {%- include "components/form/field/contenteditable/index.jinja" -%}
{%- endwith -%}
