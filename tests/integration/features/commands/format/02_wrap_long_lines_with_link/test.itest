RUN: cp %S/input.sdoc %T/
RUN: cp %S/strictdoc_config.py %T/
RUN: %strictdoc format %T/

RUN: %cat %T/input.sdoc | filecheck %s --dump-input=fail

CHECK: StrictDoc supports two input document formats: SDoc (\*.sdoc)
