{#
  TABLE VIEW — INLINE EDITING OVERVIEW
  =====================================

  This template renders all nodes as a flat table (requirements and sections).
  By default the table is in display (read-only) mode.

  ACTIVATING EDIT MODE
  ---------------------
  The toolbar button [data-testid="table-toolbar-edit-btn"] toggles edit mode.
  Clicking it adds the CSS class "table--is-editable" to <table>.
  CSS rules in table_view.css make editable cells show cursor:pointer and a
  hover outline — only when that class is present.

  CELL EDITING MODES  (data-field-type attribute on <td>)
  --------------------------------------------------------
  "singleline"
      JS (table_view_edit.js) replaces the <td> content with an <input>.
      On Enter / blur: POSTs to /actions/table/update_node_field via fetch.
      Server returns a turbo-stream that updates <div id="cell-{mid}-{field}">.

  "multiline"
      JS fetches the inline form from the URL stored in <a class="cell-edit-link">.
      Server returns a turbo-stream with a full modal-style form.
      Updates <div id="cell-{mid}-{field}">.

  "comments"
      JS fetches /actions/table/get_node_comments_inline?node_mid=...
      Server returns an inline form with multiple comment fields.
      On blur / outside click: JS POSTs the form, server updates
      <div id="cell-{mid}-COMMENT"> via turbo-stream.

  "relations-inline"
      JS fetches /actions/table/get_node_relations_inline?node_mid=...
      Server returns an inline form with relation rows (editable) and
      computed/derived relations (read-only).
      On blur / outside click: JS POSTs the form, server updates
      <div id="cell-{mid}-RELATIONS"> via turbo-stream.

  "autocomplete"
      A Stimulus controller (autocompletable) is already present in the DOM.
      Edit mode CSS hides .cell-display and shows .cell-edit-ac (contenteditable).
      On blur: JS POSTs to /actions/table/update_node_field via fetch.

  CELL EDITABILITY (is_table_cell_editable / get_table_cell_edit_mode)
  ----------------------------------------------------------------------
  Whether a field is editable depends on the document grammar for that node
  type. view_object.is_table_cell_editable() returns True if the field is
  declared in the grammar. get_table_cell_edit_mode() returns the specific
  mode: "autocomplete" | "singleline" | "multiline" | "readonly".
  Fixed fields (STATEMENT, RATIONALE, COMMENT) use is_table_cell_editable.
  Dynamic field loops use get_table_cell_edit_mode via cell_field.jinja.
#}
{%- if view_object.has_any_nodes() -%}
  <div class="main" js-pan_with_space="true">
    {% include "_shared/tags.jinja.html" %}
      <div class="content">
        <sdoc-node>
        {% include "components/node_field/document_title/index.jinja" %}
        {% include "components/node_field/document_meta/index.jinja" %}
        </sdoc-node>

        {% include "screens/document/table/filter.jinja" %}

        {# ================================================================ #}
        {# TABLE                                                             #}
        {# ================================================================ #}
        <table class="content-view-table">

          {# -- Header row ------------------------------------------------ #}
          <thead>
            <tr>
              <th class="content-view-th">Type</th>
              <th class="content-view-th">Level</th>
              {%- for meta_field_title in view_object.document.enumerate_table_meta_field_titles() -%}
                <th class="content-view-th">{{ meta_field_title }}</th>
              {%- endfor -%}
              <th class="content-view-th">REFS</th>
              <th class="content-view-th">Title</th>
              <th class="content-view-th">Statement</th>
              <th class="content-view-th">Rationale</th>
              <th class="content-view-th">Comment</th>
              {%- for content_field_title in view_object.document.enumerate_table_non_reserved_content_field_titles() -%}
                <th class="content-view-th">{{ content_field_title }}</th>
              {%- endfor -%}
            </tr>
          </thead>

          {# -- Body rows ------------------------------------------------- #}
          <tbody>
          {%- for node, _ in view_object.document_content_iterator() %}

            {# ============================================================ #}
            {# REQUIREMENT ROW                                               #}
            {# ============================================================ #}
            {%- if node.is_requirement() %}
              {%- set requirement = node %}
              {# Determine edit mode for fixed content fields up front. #}
              {%- set statement_is_editable = view_object.is_table_cell_editable(node.node_type, "STATEMENT") %}
              {%- set rationale_is_editable = view_object.is_table_cell_editable(node.node_type, "RATIONALE") %}
              {%- set comment_is_editable   = view_object.is_table_cell_editable(node.node_type, "COMMENT") %}
              <tr data-row-type="{{ node.node_type }}" data-node-mid="{{ requirement.reserved_mid }}">

                {# -- Type & Level ---------------------------------------- #}
                <td class="content-view-td content-view-td-type">
                  {{ node.node_type }}
                </td>
                <td class="content-view-td content-view-td-meta">
                  {{ requirement.context.title_number_string }}
                </td>

                {# -- Meta fields (grammar-defined, before REFS) ----------- #}
                {%- for meta_field_title in view_object.document.enumerate_table_meta_field_titles() -%}
                  {%- set field_title = meta_field_title %}
                  {%- set field_value = requirement.get_meta_field_value_by_title(field_title) %}
                  {%- set cell_edit_mode = view_object.get_table_cell_edit_mode(node.node_type, field_title) %}
                  {%- set td_class = "content-view-td content-view-td-meta" %}
                  {%- include "screens/document/table/cell_field.jinja" %}
                {%- endfor -%}

                {# -- RELATIONS: inline form, editable -------------------- #}
                <td class="content-view-td content-view-td-meta content-view-td-related"
                    data-node-mid="{{ requirement.reserved_mid }}"
                    data-field-name="RELATIONS"
                    data-field-type="relations-inline"
                    data-url="/actions/table/get_node_relations_inline?node_mid={{ requirement.reserved_mid }}">
                  <div id="cell-{{ requirement.reserved_mid }}-RELATIONS">
                    {%- include "screens/document/table/cell_relations.jinja" %}
                  </div>
                </td>

                {# -- TITLE: singleline, always editable ------------------ #}
                <td class="content-view-td content-view-td-title"
                    data-node-mid="{{ requirement.reserved_mid }}"
                    data-field-name="TITLE"
                    data-field-type="singleline"
                    data-current-value="{{ requirement.reserved_title if requirement.reserved_title else '' }}">
                  <div id="cell-{{ requirement.reserved_mid }}-TITLE">
                    {%- if requirement.reserved_title %}
                      {%- with sdoc_entity=requirement -%}
                        {% include "components/anchor/index.jinja" %}
                      {%- endwith %}
                      <sdoc-node-title>
                        {%- with field_content = requirement.reserved_title %}
                          {%- include "components/field/index.jinja" -%}
                        {%- endwith -%}
                      </sdoc-node-title>
                    {%- endif -%}
                  </div>
                </td>

                {# -- STATEMENT: multiline popup if editable -------------- #}
                {%- if statement_is_editable %}
                <td class="content-view-td content-view-td-content"
                    data-node-mid="{{ requirement.reserved_mid }}"
                    data-field-name="STATEMENT"
                    data-field-type="multiline">
                  <a class="cell-edit-link" data-turbo="false"
                     href="/actions/table/get_node_field_form?node_mid={{ requirement.reserved_mid }}&field_name=STATEMENT">
                    <div id="cell-{{ requirement.reserved_mid }}-STATEMENT">
                      {%- if requirement.has_reserved_statement() -%}
                        {# <sdoc-autogen>{{ view_object.render_node_statement(requirement) }}</sdoc-autogen> #}
                        {%- with field_content = view_object.render_node_statement(requirement) %}
                          {%- include "components/field/index.jinja" -%}
                        {%- endwith -%}
                      {%- endif -%}
                    </div>
                  </a>
                </td>
                {%- else %}
                <td class="content-view-td content-view-td-content">
                  {%- if requirement.has_reserved_statement() -%}
                    {# <sdoc-autogen>{{ view_object.render_node_statement(requirement) }}</sdoc-autogen> #}
                      {%- with field_content = view_object.render_node_statement(requirement) %}
                        {%- include "components/field/index.jinja" -%}
                      {%- endwith -%}
                  {%- endif -%}
                </td>
                {%- endif %}

                {# -- RATIONALE: multiline popup if editable -------------- #}
                {%- if rationale_is_editable %}
                <td class="content-view-td content-view-td-content"
                    data-node-mid="{{ requirement.reserved_mid }}"
                    data-field-name="RATIONALE"
                    data-field-type="multiline">
                  <a class="cell-edit-link" data-turbo="false"
                     href="/actions/table/get_node_field_form?node_mid={{ requirement.reserved_mid }}&field_name=RATIONALE">
                    <div id="cell-{{ requirement.reserved_mid }}-RATIONALE">
                      {%- if requirement.rationale -%}
                        {# <sdoc-autogen>{{ view_object.render_node_rationale(requirement) }}</sdoc-autogen> #}
                        {%- with field_content = view_object.render_node_rationale(requirement) %}
                          {%- include "components/field/index.jinja" -%}
                        {%- endwith -%}
                      {%- endif -%}
                    </div>
                  </a>
                </td>
                {%- else %}
                <td class="content-view-td content-view-td-content">
                  {%- if requirement.rationale -%}
                    {# <sdoc-autogen>{{ view_object.render_node_rationale(requirement) }}</sdoc-autogen> #}
                    {%- with field_content = view_object.render_node_rationale(requirement) %}
                      {%- include "components/field/index.jinja" -%}
                    {%- endwith -%}
                  {%- endif -%}
                </td>
                {%- endif %}

                {# -- COMMENT: inline form if editable -------------------- #}
                {%- if comment_is_editable %}
                <td class="content-view-td content-view-td-content"
                    data-node-mid="{{ requirement.reserved_mid }}"
                    data-field-name="COMMENT"
                    data-field-type="comments"
                    data-url="/actions/table/get_node_comments_inline?node_mid={{ requirement.reserved_mid }}">
                  <div id="cell-{{ requirement.reserved_mid }}-COMMENT">
                    {%- for comment_field_ in requirement.get_comment_fields() -%}
                    {# <sdoc-autogen>{{ view_object.render_node_field(comment_field_) }}</sdoc-autogen> #}
                    {%- with field_content = view_object.render_node_field(comment_field_) %}
                      {%- include "components/field/index.jinja" -%}
                    {%- endwith -%}
                    {%- endfor -%}
                  </div>
                </td>
                {%- else %}
                <td class="content-view-td content-view-td-content">
                  {%- for comment_field_ in requirement.get_comment_fields() -%}
                  {# <sdoc-autogen>{{ view_object.render_node_field(comment_field_) }}</sdoc-autogen> #}
                  {%- with field_content = view_object.render_node_field(comment_field_) %}
                    {%- include "components/field/index.jinja" -%}
                  {%- endwith -%}
                  {%- endfor -%}
                </td>
                {%- endif %}

                {# -- Non-reserved content fields (grammar-defined, after COMMENT) #}
                {%- for content_field_title in view_object.document.enumerate_table_non_reserved_content_field_titles() -%}
                  {%- set field_title = content_field_title %}
                  {%- set field_value = requirement.get_meta_field_value_by_title(field_title) %}
                  {%- set cell_edit_mode = view_object.get_table_cell_edit_mode(node.node_type, field_title) %}
                  {%- set td_class = "content-view-td" %}
                  {%- include "screens/document/table/cell_field.jinja" %}
                {%- endfor -%}

              </tr>

            {# ============================================================ #}
            {# SECTION ROW (document node = section heading)                #}
            {# ============================================================ #}
            {%- elif node.is_document() %}
              {%- set section = node %}
              <tr data-row-type="Section">
                <td class="content-view-td content-view-td-type">Section</td>
                <td class="content-view-td content-view-td-meta">{{ section.context.title_number_string }}</td>
                {# Empty cells for all meta columns #}
                {%- for meta_field_title in view_object.document.enumerate_table_meta_field_titles() -%}
                  <td class="content-view-td content-view-td-meta"></td>
                {%- endfor -%}
                {# Empty RELATIONS cell #}
                <td class="content-view-td content-view-td-meta"></td>
                {# Title spans Statement + Rationale + Comment + content fields (colspan=4) #}
                <td class="content-view-td content-view-td-title" colspan="4">
                  {%- if section.title %}
                    {%- with sdoc_entity=section -%}
                      {% include "components/anchor/index.jinja" %}
                    {%- endwith %}
                      <sdoc-node-title>
                        {%- with field_content = section.title %}
                          {%- include "components/field/index.jinja" -%}
                        {%- endwith -%}
                      </sdoc-node-title>
                    {%- for content_field_title in view_object.document.enumerate_table_non_reserved_content_field_titles() -%}
                      <td class="content-view-td">
                      </td>
                    {%- endfor -%}
                  {%- endif -%}
                </td>
              </tr>
            {%- endif %}

          {%- endfor %}
          </tbody>
        </table>
      </div>
      {# /.content #}
  </div>
  {# /.main #}
{%- else -%}
  <sdoc-main-placeholder data-testid="document-main-placeholder">
  This view is empty because
  <br />
  the document has no content.
  </sdoc-main-placeholder>
{%- endif -%}
