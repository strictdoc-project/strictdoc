<article
  class="work_planner__work_package"
  style="
    grid-column: {{ lane.grid_column_start }} / {{ lane.grid_column_end }};
    grid-row: 1 / {{ lane.row_count + 1 }};
    margin-left: calc({{ '%.6f'|format(lane.start_inset) }} * var(--work-planner-month-width));
    margin-right: calc({{ '%.6f'|format(lane.end_inset) }} * var(--work-planner-month-width));
  "
  {% if view_object.project_config.is_running_on_server and lane.node is not none %}
  draggable="true"
  data-work-planner-draggable="work-package"
  data-node-mid="{{ lane.node.reserved_mid }}"
  data-start-month-index="{{ lane.start_month_index }}"
  data-move-endpoint="/actions/work_planner/move_work_package"
  {% endif %}
>
  <div class="work_planner__work_package_header">
    <div class="work_planner__work_package_title">
      {% if lane.node is not none %}
      <a href="{{ view_object.render_node_link(lane.node) }}" data-turbo="false">
        {{ lane.title }}
      </a>
      {% else %}
      {{ lane.title }}
      {% endif %}
    </div>
    {% if view_object.project_config.is_running_on_server and lane.node is not none and lane.document is not none %}
    <div class="work_planner__work_package_actions">
      <a
        href="/actions/work_planner/new_node?element_type=EPIC&document_mid={{ lane.document.reserved_mid }}&parent_uid={{ lane.node.reserved_uid or '' }}"
        data-turbo="true"
        data-turbo-action="replace"
      >Add epic</a>
      <a
        href="/actions/work_planner/edit_node?node_id={{ lane.node.reserved_mid }}"
        data-turbo="true"
        data-turbo-action="replace"
      >Edit</a>
    </div>
    {% endif %}
  </div>
  <div class="work_planner__work_package_meta">
    {{ lane.document.title if lane.document is not none else "Project-wide" }} · {{ lane.epics|length }} epic(s)
  </div>
</article>
